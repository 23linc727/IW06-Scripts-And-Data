import pandas as pd
import ollama


df = pd.read_csv("codeMixQA_qwen.csv")
for idx, row in df.iterrows():
    if idx > 1:
        break
    prompt = row['problem'] + " 请 use 最少的 words to 回答 me."
    response = ollama.chat(
        model="qwen3.5:9b",
        messages=[{"role": "user", "content": prompt}]
    )
    df.loc[idx, 'llm_response'] = response["message"]["content"]
    df.to_csv('/Users/cindylin/Documents/IW 06/codeMixQA_qwen.csv', index=False)
    print(f"On the {idx}th response!")


